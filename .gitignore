# ============================================================
#  .gitignore — wat wel/niet in GitHub komt
# ============================================================

# --- Dependencies (worden bij elke deploy opnieuw geïnstalleerd) ---
node_modules/
.pnp
.pnp.js

# --- Build output ---
.next/
out/
build/
dist/

# --- Environment variabelen (BEVATTEN GEHEIMEN!) ---
.env
.env.local
.env.*.local
.env.development.local
.env.production.local

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- macOS / Editor rommel ---
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# --- TypeScript build info ---
*.tsbuildinfo
next-env.d.ts

# --- Vercel ---
.vercel

# --- Test coverage ---
coverage/
